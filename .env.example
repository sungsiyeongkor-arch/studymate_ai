# OpenAI API Key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Maximum characters sent to the model per request (default: 11900 ≈ 3000 tokens)
MAX_CHARS=11900

# Model temperature: 0.0 = deterministic, 1.0 = creative (default: 0.3)
TEMPERATURE=0.3

# Set to 1 to enable Flask debug mode (development only, never in production)
FLASK_DEBUG=0

# NEW: begin – Authentication & Persistence
# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_with_a_long_random_string

# Google OAuth credentials
# Get these from https://console.cloud.google.com/apis/credentials
# See README.md#google-oauth-설정 for full setup instructions
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Database URL (default: SQLite file in project directory)
# For PostgreSQL: postgresql://user:password@localhost/studymate
DATABASE_URL=sqlite:///studymate.db
# NEW: end
