# OpenAI API Key - get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Maximum characters sent to the model per request (default: 11900 ≈ 3000 tokens)
MAX_CHARS=11900

# Model temperature: 0.0 = deterministic, 1.0 = creative (default: 0.3)
TEMPERATURE=0.3

# Set to 1 to enable Flask debug mode (development only, never in production)
FLASK_DEBUG=0
